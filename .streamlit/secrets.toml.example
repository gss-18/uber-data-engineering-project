# Paste this into Streamlit Cloud → App settings → Secrets
# Fill in all values before deploying.

# ── Databricks ────────────────────────────────────────────────────────
DATABRICKS_HOST      = "https://<workspace>.cloud.databricks.com"
DATABRICKS_TOKEN     = "dapi..."
DATABRICKS_HTTP_PATH = "/sql/1.0/warehouses/<warehouse-id>"
PIPELINE_ID          = "<dlt-pipeline-id>"

# ── Azure Event Hub ───────────────────────────────────────────────────
CONNECTION_STRING          = ""   # populated automatically by Start EventHub
LISTENER_CONNECTION_STRING = ""
EVENT_HUBNAME              = ""

# ── Azure identity (for EventHub provisioning) ────────────────────────
AZURE_TENANT_ID       = "<tenant-id>"
AZURE_CLIENT_ID       = "<client-id>"
AZURE_CLIENT_SECRET   = "<client-secret>"
AZURE_SUBSCRIPTION_ID = "<subscription-id>"

# ── App auth ──────────────────────────────────────────────────────────
ADMIN_USERNAME = "your-username"
ADMIN_PASSWORD = "your-password"
SECRET_KEY     = "<random-256-bit-hex>"

# ── AI (optional — disables chat if omitted) ──────────────────────────
GEMINI_API_KEY = "<your-gemini-api-key>"
